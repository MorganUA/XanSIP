BOT_TOKEN=your_bot_token_here

# Docker: postgres/redis as service names; local dev: localhost
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/db
REDIS_URL=redis://localhost:6379/0

POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=your_db

# development | production (production: fail-fast на слабых секретах)
SIPCRM_ENV=development

# Redis AUTH (обязательно при SIPCRM_ENV=production)
REDIS_PASSWORD=

SECRET_KEY=generate_random_32_chars_minimum
SUPPORT_GROUP_ID=123456789
SUPERADMIN_TELEGRAM_ID=123456789
ADMIN_USERNAME=@admin

# Web admin login (главный суперадмин)
WEB_ADMIN_USERNAME=roof
WEB_ADMIN_PASSWORD=your_strong_web_password

# Доп. Web CRM: admin01–admin05, support01–support05
WEB_ADMIN_PRIV_PASSWORD=your_strong_admin_pool_password
WEB_ADMIN_SUPPORT_PASSWORD=your_strong_support_pool_password

COOLDOWN_MINUTES=3
MAX_TICKETS_PER_DAY=10

# Web admin panel
API_PORT=8000
# Публичный URL для Mini App (HTTPS для Telegram WebApp)
PUBLIC_WEB_URL=https://your-domain.example.com
# Принудительно secure cookie (или auto при https PUBLIC_WEB_URL)
SESSION_HTTPS_ONLY=false

# TLS reverse proxy (docker compose --profile tls up -d)
PUBLIC_WEB_DOMAIN=crm.example.com
CADDY_EMAIL=admin@example.com

# Bot ↔ CRM (Service Desk)
BOT_API_SECRET=generate_random_bot_api_secret_24_chars
BOT_WEBHOOK_URL=http://bot:8080
CRM_API_URL=http://api:8000
BOT_WEBHOOK_PORT=8080

TEST_MODE=false

# Deploy / backup — см. scripts/setup_deploy_ssh.py
# Рекомендуется ключ (пароль только для одноразового bootstrap):
#   python3 scripts/setup_deploy_ssh.py --password 'ROOT_PASSWORD'
# Проверка: python3 scripts/setup_deploy_ssh.py --test
DEPLOY_HOST=185.192.23.225
DEPLOY_USER=root
DEPLOY_SSH_KEY=~/.ssh/sipcrm_deploy_ed25519
# DEPLOY_PASSWORD=          # только bootstrap; после setup удалите
# DEPLOY_SSH_KEY_PASSPHRASE=
# DEPLOY_DIR=/opt/sipcrm
# BACKUP_INCLUDE_SECRETS=0
# BACKUP_GPG_PASSPHRASE=

# NOTIFY_SUPPORT_CHAT_IDS=-1001234567890
# NOTIFY_ADMIN_CHAT_IDS=123456789

# Notion (optional)
# NOTION_API_TOKEN=secret_xxx
# NOTION_ENABLED=false
# NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SIP trunk / WebRTC softphone (Telegram Mini App → Kolmisoft MOR / Asterisk WSS)
# SIP_TRUNK_ENABLED=true
# SIP_WSS_URL=wss://pbx.example.com:8089/ws
# SIP_DOMAIN=pbx.example.com
# SIP_DISPLAY_NAME=SIP CRM
# SIP_STUN_SERVERS=stun:stun.l.google.com:19302
# SIP_TURN_URL=turn:turn.example.com:3478?transport=udp
# SIP_TURN_USERNAME=
# SIP_TURN_CREDENTIAL=
# SIP_DIAL_PREFIX=
# SIP_OUTBOUND_PROXY=
# SIP_SESSION_TTL_SECONDS=300
